<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style>
      body { background: #0a0a0a; color: #e4e4e7; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; margin: 0; padding: 24px; }
      .wrap { max-width: 560px; margin: 0 auto; background: #18181b; border: 1px solid #27272a; border-radius: 12px; padding: 32px; }
      a { color: #34d399; }
      h1 { font-size: 20px; margin: 0 0 16px; }
      p { line-height: 1.6; margin: 0 0 16px; color: #a1a1aa; }
      .btn { display: inline-block; background: #059669; color: #fff !important; text-decoration: none; padding: 12px 20px; border-radius: 8px; font-weight: 600; }
      .footer { margin-top: 24px; font-size: 12px; color: #71717a; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <%= yield %>
      <p class="footer">Cursor Help · cursorhelp.com</p>
    </div>
  </body>
</html>
